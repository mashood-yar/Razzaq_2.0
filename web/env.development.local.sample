# Copy to web/.env.development.local (gitignored).
# Next.js merges this with .env.local in development; this file wins on conflicts.
# Keeps Supabase keys when you run: vercel env pull .env.local

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
