# Copy to `.env.local` for local Next.js (`web/` is the Next app root).
# Never commit real secrets — add the same keys in Vercel → Project → Environment Variables.

# ─── SUPABASE (required for Auth + Postgres) ───────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional dashboard alias — same permission level as anon key when using newer Supabase UX:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-side only — never expose publicly (admin scripts, privileged webhooks, storage delete):
SUPABASE_SERVICE_ROLE_KEY=

# ─── APP / ROUTING ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional alias used by auth actions for OTP / reset redirects:
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── BANK TRANSFER LABELS — shown on `/checkout` (public, shipped to browser)
NEXT_PUBLIC_CHECKOUT_BANK_NAME=
NEXT_PUBLIC_CHECKOUT_BANK_ACCOUNT_TITLE=
NEXT_PUBLIC_CHECKOUT_BANK_ACCOUNT_NUMBER=
NEXT_PUBLIC_CHECKOUT_UPAISA_NUMBER=

# ─── SANITY CMS ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=
SANITY_WEBHOOK_SECRET=

# ─── xAI (Shop chat bot — `app/api/chat`) ────────────────────────────────────
XAI_API_KEY=
XAI_CHAT_MODEL=

# ─── EMAIL (RESEND) ─────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
RESEND_BOUNCE_ALERT_EMAIL=
RESEND_FROM_EMAIL=

# ─── INTERNATIONAL CARD CHECKOUT (Stripe) ─────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── PAKISTAN HOSTED CARD CHECKOUT — SAFEPAY ───────────────────────────────
SAFEPAY_API_KEY=
SAFEPAY_WEBHOOK_SECRET=
SAFEPAY_ENV=sandbox
SAFEPAY_API_BASE_URL=
SAFEPAY_CHECKOUT_BASE_URL=

# ─── PAYFAST — integration disabled but env + code retained for revive ─────
PAYFAST_MERCHANT_ID=
PAYFAST_SECURED_KEY=
PAYFAST_API_URL=
PAYFAST_MERCHANT_NAME=

# ─── JAZZCASH (mobile wallet) ────────────────────────────────────────────────
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_API_URL=

# ─── LEMON SQUEEZY — legacy fallback when Stripe is off ────────────────────
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_PRODUCT_VARIANT_ID=

# ─── CLOUDINARY (admin upload/delete APIs — server only except NEXT_PUBLIC_* name) ─
# Same cloud appears in BOTH name vars if you use both; NEXT_PUBLIC_* is optional.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
#
# Paste API Key + API Secret from Dashboard → Settings → API for the SAME cloud name.
# If uploads return "Invalid api_key (HTTP 401)", the trio does not belong to one Cloudinary product.

# ─── CARRIER / ERP INTEGRATIONS (optional fulfilment helpers) ───────────────
EXCHANGE_RATE_API_KEY=
TCS_API_URL=
TCS_API_KEY=
TCS_ACCOUNT_NUMBER=
TCS_SENDER_NAME=
TCS_SENDER_PHONE=
TCS_SENDER_ADDRESS=
LEOPARDS_API_URL=
LEOPARDS_API_KEY=
LEOPARDS_API_PASSWORD=
LEOPARDS_ORIGIN_CITY=Rawalpindi
DHL_API_URL=
DHL_API_KEY=
DHL_API_SECRET=
DHL_ACCOUNT_NUMBER=
DHL_SENDER_NAME=
DHL_SENDER_PHONE=
DHL_SENDER_COUNTRY=
DHL_SENDER_CITY=
DHL_SENDER_POSTAL=
DHL_SENDER_ADDRESS=
