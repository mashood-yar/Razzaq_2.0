# ─── SUPABASE ───────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Optional newer dashboard key name:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── SANITY ─────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=
SANITY_WEBHOOK_SECRET=

# ─── APP ───────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── xAI (Chat API — app/api/chat) ───────────────
# https://console.x.ai — never commit the real key
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional (default grok-beta). Examples: grok-2-latest, grok-beta
XAI_CHAT_MODEL=

# ─── RESEND (Email) ──────────────────────────────
# Replace re_xxxxxxxxx with your real API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxx
# From Resend → Webhooks → your endpoint → Signing secret (starts with whsec_)
# Required for POST /api/webhooks/resend (verification uses this only, not RESEND_API_KEY)
RESEND_WEBHOOK_SECRET=
# Optional: receive bounce/complaint alerts for tagged order emails
RESEND_BOUNCE_ALERT_EMAIL=
RESEND_FROM_EMAIL=orders@yourdomain.com

# ─── JAZZCASH (optional — Pakistan Mobile Wallet MWALLET REST API) ────────
# Merchant Portal / sandbox: https://sandbox.jazzcash.com.pk
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
# Sandbox default (switch host for live):
JAZZCASH_API_URL=https://sandbox.jazzcash.com.pk/ApplicationAPI/API/2.0/Purchase/DoMWalletTransaction

# ─── PAYFAST PAKISTAN (optional — hosted checkout sandbox.payfast.pk) ─────
PAYFAST_MERCHANT_ID=
PAYFAST_SECURED_KEY=
PAYFAST_API_URL=https://sandbox.payfast.pk
# Display name sent to PayFast hosted form
PAYFAST_MERCHANT_NAME=Razzaq Luxe

# ─── STRIPE (optional — international cards via Hosted Checkout) ──
# Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe Dashboard → Developers → Webhooks → Signing secret (endpoint: /api/webhooks/stripe)
STRIPE_WEBHOOK_SECRET=

# ─── SAFEPAY (Pakistan — cards + wallets on hosted checkout) ──
# Dashboard: sandbox API key as POST /order/v1/init `client` (see @sfpy/node-sdk).
SAFEPAY_API_KEY=
# Developers → Endpoints → shared secret for HMAC-SHA512 (header x-sfpy-signature)
SAFEPAY_WEBHOOK_SECRET=
# sandbox | live — controls API host + checkout `env` query param
SAFEPAY_ENV=sandbox
# Optional overrides (defaults match @sfpy/node-sdk v3.x):
# SAFEPAY_API_BASE_URL=https://sandbox.api.getsafepay.com
# SAFEPAY_CHECKOUT_BASE_URL=https://sandbox.api.getsafepay.com/checkout

# ─── TCS PAKISTAN ────────────────────────────────
TCS_API_URL=https://api.tcsexpress.com/api
TCS_API_KEY=
TCS_ACCOUNT_NUMBER=
TCS_SENDER_NAME=LUMINA
TCS_SENDER_PHONE=+92XXXXXXXXXX
TCS_SENDER_ADDRESS=Your address

# ─── LEOPARDS COURIER ────────────────────────────
LEOPARDS_API_URL=https://merchantapi.leopardscourier.com/api
LEOPARDS_API_KEY=
LEOPARDS_API_PASSWORD=
LEOPARDS_ORIGIN_CITY=Rawalpindi

# ─── DHL ─────────────────────────────────────────
DHL_API_URL=https://api-mock.dhl.com/mydhlapi
DHL_API_KEY=
DHL_API_SECRET=
DHL_ACCOUNT_NUMBER=
DHL_SENDER_NAME=LUMINA
DHL_SENDER_PHONE=+92XXXXXXXXXX
DHL_SENDER_COUNTRY=PK
DHL_SENDER_CITY=Rawalpindi
DHL_SENDER_POSTAL=46000
DHL_SENDER_ADDRESS=Your address
